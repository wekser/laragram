// Labels are translated; the callback data ('/click Foo') stays stable so the
// route '/click {name}' keeps matching regardless of the user's language.
button(__('laragram.start.btn_foo'), '/click Foo');
button(__('laragram.start.btn_bar'), '/click Bar');

// A second row with a URL button (href) — opens a link instead of firing a callback.
row();
href(__('laragram.start.btn_repo'), 'https://github.com/wekser/laragram');
